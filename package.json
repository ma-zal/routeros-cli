{
  "name": "routeros-cli",
  "version": "0.1.0",
  "description": "MikroTik RouterOS CLI and Node.js library via Telnet",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "roscli": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mikrotik",
    "routeros",
    "cli",
    "telnet",
    "router",
    "network",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ma-zal/routeros-cli.git"
  },
  "homepage": "https://github.com/ma-zal/routeros-cli",
  "bugs": {
    "url": "https://github.com/ma-zal/routeros-cli/issues"
  },
  "author": {
    "name": "Martin Zaloudek",
    "url": "https://github.com/ma-zal"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "12.1.0",
    "dotenv": "16.6.1"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  }
}
